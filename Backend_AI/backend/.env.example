NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/ston

FRONTEND_URL=http://localhost:5173
ADMIN_FRONTEND_URL=
CORS_ALLOWED_ORIGINS=

PLATFORM_ADMIN_EMAIL=admin@example.com

JWT_SECRET=REPLACE_WITH_AT_LEAST_32_CHARACTER_SECRET
JWT_EXPIRES_IN=1h
JWT_ISSUER=ston-backend
JWT_AUDIENCE=ston-frontend

BCRYPT_ROUNDS=12
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

CSRF_REQUIRED=false

OTP_HMAC_SECRET=
EMAIL_VERIFICATION_REQUIRED=false
EMAIL_VERIFICATION_OTP_TTL_MINUTES=10
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
HEALTH_CHECK_KEY=

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_STUDENT_LOGIN_MAX=5
RATE_LIMIT_ADMIN_LOGIN_MAX=3
RATE_LIMIT_INVITE_MAX=20
RATE_LIMIT_SIGNUP_MAX=10
RATE_LIMIT_DEPARTMENT_CREATE_MAX=20

TRUST_PROXY=false
JSON_BODY_LIMIT=8mb

LOG_LEVEL=info
LOG_PRETTY=false

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_MODEL=
REQUIRE_AZURE_OPENAI=false
AI_HTTP_TIMEOUT_MS=20000
AI_MAX_RETRIES=2
INVITE_EXPIRY_HOURS=168
DEFAULT_COLLEGE_DEPARTMENT_LIMIT=0
